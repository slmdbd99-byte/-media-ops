<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>七赛道孵化作战手册 · 东华大学新媒体运营</title>
<meta name="description" content="44 名学员 · 7 赛道 · 调研即内容 · 零基础可跑通的内容引擎">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@500;700;900&family=Noto+Sans+SC:wght@400;500;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0B1026; --ink2:#141B33; --panel:#18203c; --panel2:#1d2748;
  --line:rgba(201,162,75,.20); --line2:rgba(255,255,255,.07);
  --gold:#C9A24B; --gold2:#E7C57E; --teal:#58D6C0; --rose:#E89079;
  --tx:#ECE8DD; --mut:#9AA6C4; --mut2:#6f7aa0;
  --serif:"Noto Serif SC",Georgia,"Songti SC",serif;
  --sans:"Noto Sans SC",system-ui,"PingFang SC",-apple-system,sans-serif;
  --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,monospace;
  --rail:248px; --max:1080px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{
  background:var(--ink); color:var(--tx); font-family:var(--sans);
  font-size:16px; line-height:1.65; letter-spacing:.01em;
  background-image:
    linear-gradient(rgba(201,162,75,.035) 1px,transparent 1px),
    linear-gradient(90deg,rgba(201,162,75,.035) 1px,transparent 1px),
    radial-gradient(1200px 600px at 80% -10%,rgba(88,214,192,.06),transparent),
    radial-gradient(1000px 500px at -10% 10%,rgba(201,162,75,.07),transparent);
  background-size:46px 46px,46px 46px,100% 100%,100% 100%;
}
a{color:inherit;text-decoration:none}
em{font-style:normal;color:var(--gold2)}
small{font-size:.78em}
::selection{background:rgba(201,162,75,.3)}

/* layout */
.shell{display:flex;min-height:100vh}
.rail{
  width:var(--rail);flex:0 0 var(--rail);position:sticky;top:0;height:100vh;
  border-right:1px solid var(--line);padding:26px 20px;background:linear-gradient(180deg,#0d1330,#0a0f24);
  display:flex;flex-direction:column;gap:8px;z-index:40
}
.brand{font-family:var(--mono);font-size:11px;letter-spacing:.22em;color:var(--gold);margin-bottom:6px}
.brand b{display:block;font-family:var(--serif);font-size:19px;font-weight:900;letter-spacing:.02em;color:var(--tx);margin-top:6px;line-height:1.3}
.nav{display:flex;flex-direction:column;gap:2px;margin-top:14px}
.nav a{
  font-size:14.5px;padding:10px 12px;border-radius:9px;color:var(--mut);display:flex;align-items:center;gap:10px;
  border:1px solid transparent;transition:.18s
}
.nav a:hover{color:var(--tx);background:rgba(255,255,255,.04)}
.nav a.on{color:var(--ink);background:linear-gradient(90deg,var(--gold2),var(--gold));font-weight:700;border-color:var(--gold)}
.nav a .ico{font-size:15px;width:20px;text-align:center}
.nav .navnum{margin-left:auto;font-family:var(--mono);font-size:10px;opacity:.7}
.rail .foot{margin-top:auto;font-size:11px;color:var(--mut2);line-height:1.6;border-top:1px solid var(--line2);padding-top:14px}

.main{flex:1;min-width:0}
.wrap{max-width:var(--max);margin:0 auto;padding:46px 30px 90px}

/* topbar (mobile) */
.topbar{display:none;position:sticky;top:0;z-index:50;align-items:center;justify-content:space-between;
  padding:12px 16px;background:rgba(11,16,38,.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
.topbar b{font-family:var(--serif);font-weight:900;font-size:15px}
.topbar .burger{font-size:22px;background:none;border:1px solid var(--line);color:var(--gold);border-radius:8px;width:40px;height:38px}
.scrim{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:45}

/* hero */
.hero,.phead{border-bottom:1px solid var(--line);padding-bottom:30px;margin-bottom:34px}
.eyebrow{font-family:var(--mono);font-size:11.5px;letter-spacing:.2em;color:var(--gold);text-transform:uppercase;display:flex;flex-wrap:wrap;align-items:center;gap:10px}
.cls{font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:var(--ink);background:var(--rose);padding:2px 8px;border-radius:4px;font-weight:700}
.hero h1{font-family:var(--serif);font-weight:900;font-size:clamp(28px,5.2vw,50px);line-height:1.14;margin:18px 0 14px;letter-spacing:.01em}
.phead h1{font-family:var(--serif);font-weight:900;font-size:clamp(26px,4.6vw,42px);line-height:1.16;margin:16px 0 12px}
.lede{font-size:clamp(15px,1.7vw,18px);color:var(--mut);max-width:62ch}
.lede.tight{margin-bottom:4px}

/* engine signature */
.engine{display:flex;align-items:center;flex-wrap:wrap;gap:0;margin:30px 0 8px}
.enode{flex:1 1 130px;min-width:120px;border:1px solid var(--line);border-radius:12px;padding:16px 14px;
  background:linear-gradient(180deg,var(--panel),var(--ink2));position:relative;opacity:0;transform:translateY(10px);transition:.5s cubic-bezier(.2,.7,.3,1)}
.enode.in{opacity:1;transform:none}
.enode .ei{font-family:var(--mono);font-size:11px;color:var(--gold);letter-spacing:.1em}
.enode .et{display:block;font-family:var(--serif);font-weight:700;font-size:17px;margin-top:6px}
.econn{flex:0 0 30px;height:2px;background:linear-gradient(90deg,var(--gold),transparent);position:relative;align-self:center;margin:0 -1px}
.econn i{position:absolute;right:-2px;top:-3px;width:8px;height:8px;border-top:2px solid var(--gold);border-right:2px solid var(--gold);transform:rotate(45deg)}

/* stats */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:26px 0}
.stats>div{border:1px solid var(--line2);border-radius:12px;padding:16px;background:rgba(255,255,255,.02)}
.stats b{font-family:var(--serif);font-size:30px;font-weight:900;color:var(--gold2);display:block;line-height:1}
.stats span{font-size:12.5px;color:var(--mut);display:block;margin-top:6px}

.cta-row{display:flex;flex-wrap:wrap;gap:12px;margin-top:8px}
.btn{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:14.5px;padding:12px 20px;border-radius:10px;border:1px solid var(--line);cursor:pointer;transition:.18s;font-family:var(--sans)}
.btn.gold{background:linear-gradient(90deg,var(--gold2),var(--gold));color:#1a1404;border-color:var(--gold)}
.btn.gold:hover{filter:brightness(1.07);transform:translateY(-1px)}
.btn.ghost{background:transparent;color:var(--tx)}
.btn.ghost:hover{border-color:var(--gold);color:var(--gold2)}
.btn.sm{padding:8px 14px;font-size:13px}

/* sections */
.block{margin:38px 0}
.sec{font-family:var(--serif);font-weight:700;font-size:clamp(20px,2.6vw,27px);display:flex;align-items:center;gap:12px;margin-bottom:18px}
.sec .dot{width:9px;height:9px;background:var(--gold);border-radius:50%;box-shadow:0 0 0 4px rgba(201,162,75,.15)}
.note{color:var(--mut);font-size:14px;margin:-8px 0 16px;max-width:70ch}
.micro{color:var(--mut2);font-size:12px;margin-top:8px}

/* grids & cards */
.grid{display:grid;gap:16px}
.grid.tracks{grid-template-columns:repeat(auto-fill,minmax(240px,1fr))}
.grid.g3{grid-template-columns:repeat(auto-fill,minmax(230px,1fr))}
.card{border:1px solid var(--line2);border-radius:14px;background:linear-gradient(180deg,var(--panel),var(--ink2));padding:20px;transition:.18s}
.card.track{border-color:var(--line);position:relative;overflow:hidden}
.card.track:before{content:"";position:absolute;inset:0 0 auto 0;height:3px;background:var(--ac,var(--gold))}
.card.track:hover{transform:translateY(-3px);border-color:var(--ac,var(--gold))}
.tk-top{display:flex;justify-content:space-between;align-items:center}
.tk-top .emoji{font-size:26px}
.tk-top .code{font-family:var(--mono);font-size:12px;color:var(--ac,var(--gold));border:1px solid var(--line);padding:2px 8px;border-radius:20px}
.card.track h3{font-family:var(--serif);font-size:22px;font-weight:900;margin:12px 0 6px}
.card.track p{font-size:13.5px;color:var(--mut);min-height:38px}
.tk-foot{display:flex;justify-content:space-between;font-size:12px;color:var(--mut2);margin-top:14px;border-top:1px solid var(--line2);padding-top:10px;font-family:var(--mono)}

.card.lead .lead-h{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.gtag{font-family:var(--mono);font-weight:700;font-size:13px;color:var(--ink);background:var(--gold);padding:2px 9px;border-radius:6px}
.lead-h .trk{font-size:13px;color:var(--mut)}
.lead-n{font-family:var(--serif);font-weight:700;font-size:17px}
.lead-n small{color:var(--gold2);font-family:var(--sans);font-weight:500}
.lead-m{display:flex;flex-wrap:wrap;gap:5px;margin-top:12px}
.lead-m span{font-size:11.5px;color:var(--mut);font-family:var(--mono);background:rgba(255,255,255,.03);padding:3px 7px;border-radius:6px}

.how{list-style:none;counter-reset:h;display:grid;gap:10px}
.how li{counter-increment:h;position:relative;padding:14px 16px 14px 52px;border:1px solid var(--line2);border-radius:12px;font-size:14.5px;color:var(--mut)}
.how li:before{content:counter(h);position:absolute;left:14px;top:13px;font-family:var(--mono);font-weight:700;color:var(--ink);background:var(--gold);width:26px;height:26px;border-radius:7px;display:grid;place-items:center;font-size:13px}
.how b{color:var(--tx)}
.tip{background:linear-gradient(180deg,rgba(88,214,192,.05),transparent);border:1px solid var(--line2);border-radius:16px;padding:8px 22px 22px}

@media print{.rail,.topbar,.scrim,.cta-row,.tools-skip{display:none!important}.main{width:100%}.wrap{max-width:100%;padding:0}body{background:#fff;color:#111}.card,.enode{break-inside:avoid}}
/* SOP */
.sop{display:grid;gap:12px}
.sop-step{display:flex;gap:16px;border:1px solid var(--line2);border-radius:13px;padding:16px 18px;background:rgba(255,255,255,.02)}
.sop-step .sn{font-family:var(--mono);font-weight:700;font-size:22px;color:var(--gold);flex:0 0 auto;line-height:1.2}
.sop-step h4{font-family:var(--serif);font-size:17px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.sop-step h4 .who{font-family:var(--mono);font-size:10.5px;color:var(--teal);border:1px solid rgba(88,214,192,.3);padding:1px 8px;border-radius:20px;font-weight:500}
.sop-step p{font-size:14px;color:var(--mut)}
.sop-step .meta{display:flex;flex-wrap:wrap;gap:8px 18px;margin-top:8px;font-size:12px;color:var(--mut2);font-family:var(--mono)}
.sop-step .meta .z{color:var(--teal)}

/* research-as-content pipeline */
.pipe{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;counter-reset:pp}
.pstep{counter-increment:pp;border:1px solid var(--line);border-radius:13px;padding:16px;background:linear-gradient(180deg,var(--panel),var(--ink2));position:relative}
.pstep:before{content:"步骤 "counter(pp);font-family:var(--mono);font-size:10px;color:var(--gold);letter-spacing:.1em}
.pstep h4{font-family:var(--serif);font-size:16px;margin:6px 0}
.pstep p{font-size:13px;color:var(--mut)}
.loopback{text-align:center;font-family:var(--mono);font-size:12px;color:var(--teal);margin-top:14px}

/* tools */
.tool{border:1px solid var(--line);border-radius:16px;padding:22px;margin:16px 0;background:linear-gradient(180deg,var(--panel),var(--ink2))}
.tool h3{font-family:var(--serif);font-size:19px;font-weight:700;margin-bottom:4px}
.tool h3 b{color:var(--gold)}
.tdesc{font-size:13.5px;color:var(--mut);margin-bottom:14px}
.tform{display:flex;flex-wrap:wrap;gap:14px;align-items:flex-end}
.tform label,.bpi label{font-size:12.5px;color:var(--mut);display:flex;flex-direction:column;gap:6px}
input,select{font-family:var(--sans);font-size:14px;background:var(--ink);border:1px solid var(--line2);color:var(--tx);border-radius:9px;padding:9px 11px}
input:focus,select:focus{outline:none;border-color:var(--gold)}
input[type=number]{width:110px}
.inline{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--mut)}
.tout{margin-top:16px}
.tout .res{border:1px dashed var(--line);border-radius:12px;padding:16px;background:rgba(201,162,75,.04)}
.tout .verdict{font-family:var(--serif);font-size:20px;font-weight:700;margin-bottom:6px}
.bar{height:12px;border-radius:7px;background:linear-gradient(90deg,var(--gold),var(--gold2));margin:4px 0}
.allocrow{display:flex;align-items:center;gap:12px;margin:8px 0;font-size:14px}
.allocrow .lab{flex:0 0 130px;color:var(--mut)}
.allocrow .barwrap{flex:1;background:rgba(255,255,255,.05);border-radius:7px;overflow:hidden}
.allocrow .v{flex:0 0 80px;text-align:right;font-family:var(--mono);color:var(--gold2)}
.bpi{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;margin-bottom:14px}
.bpi .sv{display:flex;flex-direction:column;gap:6px;font-size:13px}
.bpi .sv .row{display:flex;justify-content:space-between;align-items:center}
.bpi input[type=range]{width:100%;accent-color:var(--gold)}
.scorebig{font-family:var(--mono);font-size:42px;font-weight:700;color:var(--gold2);line-height:1}

.dtbl-wrap{overflow-x:auto;border:1px solid var(--line2);border-radius:12px}
.dtbl{width:100%;border-collapse:collapse;font-size:13px;min-width:640px}
.dtbl th{font-family:var(--mono);font-size:11px;letter-spacing:.05em;color:var(--gold);text-align:left;padding:10px;border-bottom:1px solid var(--line);background:rgba(201,162,75,.05);white-space:nowrap}
.dtbl td{padding:7px 10px;border-bottom:1px solid var(--line2)}
.dtbl td input{width:78px;padding:6px 8px}
.dtbl td.calc{font-family:var(--mono);color:var(--gold2)}
.dtbl tr.best td{background:rgba(88,214,192,.08)}
.dtbl .del{background:none;border:none;color:var(--rose);cursor:pointer;font-size:16px}
.dtbar{display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-top:12px}

/* track page */
.tpane{border:1px solid var(--line);border-radius:16px;padding:22px;margin:16px 0;background:linear-gradient(180deg,var(--panel),var(--ink2))}
.tpane h3{font-family:var(--serif);font-size:20px;font-weight:700;display:flex;align-items:center;gap:10px;margin-bottom:12px}
.tpane h3 .tn{font-family:var(--mono);font-size:11px;color:var(--ac,var(--gold));border:1px solid var(--line);border-radius:20px;padding:2px 9px}
.tlist{list-style:none;display:grid;gap:8px}
.tlist li{font-size:14.5px;color:var(--mut);padding-left:20px;position:relative}
.tlist li:before{content:"▹";position:absolute;left:0;color:var(--ac,var(--gold))}
.tlist li b,.tpane p b{color:var(--tx)}
.tband{display:flex;flex-wrap:wrap;gap:8px;margin:2px 0 6px}
.tband a{font-size:13px;color:var(--mut);border:1px solid var(--line2);padding:6px 12px;border-radius:9px;font-family:var(--mono)}
.tband a:hover{border-color:var(--gold);color:var(--gold2)}
.qa{counter-reset:q;display:grid;gap:7px}
.qa li{counter-increment:q;list-style:none;font-size:14px;color:var(--mut);padding-left:34px;position:relative}
.qa li:before{content:"Q"counter(q);position:absolute;left:0;top:0;font-family:var(--mono);font-size:11px;color:var(--ac,var(--gold));font-weight:700}
.qa li.opt:before{content:"Q"counter(q);}
.subh{font-family:var(--mono);font-size:12px;letter-spacing:.08em;color:var(--gold);margin:16px 0 8px;text-transform:uppercase}
.bp{border-left:3px solid var(--gold);padding:4px 0 4px 18px;display:grid;gap:12px}
.bp p{font-size:14px;color:var(--mut)}
.bp p b{color:var(--gold2);font-family:var(--serif)}

/* people */
.pfilter{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px}
.pfilter button{font-family:var(--sans);font-size:13px;padding:7px 14px;border-radius:20px;border:1px solid var(--line2);background:transparent;color:var(--mut);cursor:pointer;transition:.15s}
.pfilter button:hover{color:var(--tx)}
.pfilter button.on{background:var(--gold);color:var(--ink);border-color:var(--gold);font-weight:700}
.pcards{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:16px}
.pcard{border:1px solid var(--line2);border-radius:14px;background:linear-gradient(180deg,var(--panel),var(--ink2));padding:18px;display:flex;flex-direction:column;gap:10px}
.pcard .ph{display:flex;align-items:flex-start;justify-content:space-between;gap:10px}
.pcard .pid{font-family:var(--mono);font-size:12px;color:var(--gold)}
.pcard .pn{font-family:var(--serif);font-size:21px;font-weight:900}
.pcard .pn small{font-family:var(--sans);font-weight:400;color:var(--mut);font-size:12px;margin-left:6px}
.pcard .ptrk{font-family:var(--mono);font-size:11px;padding:3px 9px;border-radius:20px;border:1px solid var(--line);color:var(--gold2);white-space:nowrap}
.pbadges{display:flex;flex-wrap:wrap;gap:5px}
.pbadges span{font-size:10.5px;font-family:var(--mono);color:var(--mut);background:rgba(255,255,255,.04);padding:2px 7px;border-radius:5px}
.pbadges span.lead{background:var(--gold);color:var(--ink);font-weight:700}
.pbadges span.res{background:rgba(88,214,192,.14);color:var(--teal)}
.prole{font-size:13px;color:var(--gold2);font-weight:500}
.pstr{font-size:13px;color:var(--mut2);border-top:1px solid var(--line2);padding-top:10px}
.pcard .more{font-size:13px;color:var(--teal);cursor:pointer;font-family:var(--mono)}
.pcard .detail{display:none}
.pcard.open .detail{display:block}
.pcard .detail h5{font-size:12px;font-family:var(--mono);color:var(--gold);letter-spacing:.06em;margin:12px 0 6px;text-transform:uppercase}
.pcard .detail ul{list-style:none;display:grid;gap:6px}
.pcard .detail li{font-size:13px;color:var(--mut);padding-left:16px;position:relative}
.pcard .detail li:before{content:"·";position:absolute;left:4px;color:var(--gold)}
.pcard .mates{display:flex;flex-wrap:wrap;gap:6px}
.pcard .mates a{font-size:11px;font-family:var(--mono);color:var(--mut);border:1px solid var(--line2);padding:3px 8px;border-radius:6px}
.pcard .mates a:hover{border-color:var(--gold);color:var(--gold2)}
.pcard .pbtns{display:flex;gap:8px;margin-top:4px}
.copybtn{flex:1;font-family:var(--sans);font-size:13px;font-weight:700;padding:9px;border-radius:9px;border:1px solid var(--gold);background:transparent;color:var(--gold2);cursor:pointer;transition:.15s}
.copybtn:hover{background:var(--gold);color:var(--ink)}
.copybtn.done{background:var(--teal);color:var(--ink);border-color:var(--teal)}

/* person detail page */
.chip{display:inline-flex;flex-direction:column;border:1px solid var(--line2);border-radius:10px;padding:8px 12px;font-size:13px}
.chip small{color:var(--mut2);font-size:11px}

.depthead{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin:16px 0}

@media (max-width:880px){
  .rail{position:fixed;left:0;top:0;transform:translateX(-100%);transition:.25s;box-shadow:8px 0 30px rgba(0,0,0,.4)}
  body.navopen .rail{transform:none}
  body.navopen .scrim{display:block}
  .topbar{display:flex}
  .wrap{padding:24px 18px 80px}
  .stats{grid-template-columns:repeat(2,1fr)}
  .econn{display:none}
  .enode{flex:1 1 44%}
}
@media (max-width:520px){
  .pcards{grid-template-columns:1fr}
  .bpi{grid-template-columns:1fr 1fr}
  .stats b{font-size:24px}
}
@media (prefers-reduced-motion:reduce){*{transition:none!important}.enode{opacity:1;transform:none}}
</style>
</head>
<body>
<div class="scrim" onclick="closeNav()"></div>
<header class="topbar">
  <button class="burger" onclick="toggleNav()" aria-label="菜单">☰</button>
  <b>七赛道作战手册</b>
  <span style="font-family:var(--mono);font-size:11px;color:var(--gold)">DHU</span>
</header>
<div class="shell">
  <aside class="rail">
    <div class="brand">CONFIDENTIAL · 绝密<b>七赛道孵化<br>作战手册</b></div>
    <nav class="nav">
