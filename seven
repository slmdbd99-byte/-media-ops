/* ===== 复制任务卡 ===== */
function copyPerson(n,btn){
 const p=byNum(n); if(!p) return;
 const t=GROUPS[p.g]; const L=leaderOf(p.g); const mates=gm(p.g).filter(m=>m.n!==p.n);
 let s="【新媒体运营 · 个人任务卡】\n";
 s+="编号:#"+p.n+"   姓名:"+p.name+"   班级:"+p.cls+(p.sid?("   学号:"+p.sid):"")+"\n";
 s+="赛道:"+t.emoji+" "+t.track+"(G"+p.g+" 组)   组长:#"+L.n+" "+L.name+"\n";
 s+="角色:"+p.role+(p.res?"(市场调研核心岗)":"")+"\n\n";
 s+="▍个人任务(全流程)\n";
 p.tasks.forEach((x,i)=>{s+=(i+1)+". "+x+"\n";});
 s+="\n▍同组成员名单与各自任务\n";
 mates.forEach(m=>{s+="● #"+m.n+" "+m.name+" — "+m.role+"\n";m.tasks.forEach(x=>{s+="   - "+x+"\n";});});
 s+="\n— 东华大学人文学院 · 新媒体运营实战项目 · "+t.track+"赛道";
 const done=()=>{const o=btn.textContent;btn.textContent="已复制 ✓";btn.classList.add("done");setTimeout(()=>{btn.textContent=o;btn.classList.remove("done");},2000);};
 if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(s).then(done).catch(()=>fallback(s,done));}
 else fallback(s,done);
}
function fallback(s,cb){const ta=document.createElement("textarea");ta.value=s;ta.style.position="fixed";ta.style.opacity="0";document.body.appendChild(ta);ta.select();try{document.execCommand("copy");cb();}catch(e){alert("复制失败,请手动选择文本");}document.body.removeChild(ta);}

/* ===== 工具绑定 ===== */
const BPI_DIMS=[["钩子强度(前3秒)",0.18],["情绪共鸣",0.16],["实用/收藏价值",0.14],["新奇/反差感",0.12],["视觉质感",0.12],["参与互动设计",0.12],["发布时机",0.08],["平台契合度",0.08]];

function bindTools(){
 // ① 分配器
 const alGo=$("#al-go");
 if(alGo) alGo.onclick=()=>{
   const n=Math.max(1,Math.min(50,+$("#al-n").value||10)), s=$("#al-s").value; let rows=[],tip="";
   if(s==="focus"){const main=Math.round(n*0.7);rows=[["主投放(目标细分)",main],["对照组(同细分变量)",n-main]];tip="把火力压在最有把握的单一细分,用对照组验证因果。72 小时即可得到明确结论,再放大。";}
   else if(s==="spread"){const segs=["细分A","细分B","细分C","细分D","细分E"];const base=Math.floor(n/5),rem=n%5;rows=segs.map((x,i)=>[x,base+(i<rem?1:0)]);tip="把样品摊到 5 个细分广撒网,先找出哪个细分反应最强,再集中放大。适合赛道方向未定时。";}
   else {const half=Math.floor(n/2);rows=[["A 版(原方案)",half],["B 版(单一变量)",n-half]];tip="同一细分只改一个变量(封面/钩子/价格),其余完全一致,用结果判断该变量影响。";}
   const max=Math.max(...rows.map(r=>r[1]));
   $("#al-out").innerHTML='<div class="res">'+rows.map(r=>'<div class="allocrow"><span class="lab">'+r[0]+'</span><span class="barwrap"><span class="bar" style="width:'+(r[1]/max*100)+'%"></span></span><span class="v">'+r[1]+' 份</span></div>').join("")+'<p class="micro" style="margin-top:10px">▸ '+tip+'</p></div>';
 };
 // ② 样本量
 const ssGo=$("#ss-go");
 if(ssGo) ssGo.onclick=()=>{
   const N=Math.max(30,+$("#ss-N").value||3000), z=+$("#ss-z").value, e=Math.max(1,+$("#ss-e").value||8)/100;
   const n0=(z*z*0.25)/(e*e); const n=Math.ceil(n0/(1+(n0-1)/N)); const rec=Math.ceil(n*1.2);
   $("#ss-out").innerHTML='<div class="res"><div class="verdict">建议有效问卷 ≈ '+n+' 份</div>'+
     '<p class="micro">考虑废卷,实际发放建议 <b style="color:var(--gold2)">'+rec+' 份</b>(×1.2 缓冲)。</p>'+
     '<p style="margin-top:10px;font-size:13.5px;color:var(--mut)">分层配额参考(按性别均分 + 年级分布):</p>'+
     '<div class="allocrow"><span class="lab">大一/大二</span><span class="barwrap"><span class="bar" style="width:55%"></span></span><span class="v">'+Math.round(n*0.55)+' 份</span></div>'+
     '<div class="allocrow"><span class="lab">大三/大四</span><span class="barwrap"><span class="bar" style="width:30%"></span></span><span class="v">'+Math.round(n*0.30)+' 份</span></div>'+
     '<div class="allocrow"><span class="lab">研究生/其他</span><span class="barwrap"><span class="bar" style="width:15%"></span></span><span class="v">'+Math.round(n*0.15)+' 份</span></div>'+
     '<p class="micro" style="margin-top:8px">▸ 配合 10–12 人深访做质性补充;深访按细分人群各 3 人覆盖。</p></div>';
 };
 // ③ BPI
 const bf=$("#bpi-form");
 if(bf&&!bf.dataset.built){bf.dataset.built="1";bf.innerHTML=BPI_DIMS.map((d,i)=>'<div class="sv"><div class="row"><span>'+d[0]+'</span><span id="bv'+i+'" style="font-family:var(--mono);color:var(--gold2)">60</span></div><input type="range" min="0" max="100" value="60" data-i="'+i+'" oninput="document.getElementById(\'bv\'+this.dataset.i).textContent=this.value"></div>').join("");}
 const bGo=$("#bpi-go");
 if(bGo) bGo.onclick=()=>{
   let sc=0;$$("#bpi-form input[type=range]").forEach(r=>{sc+=(+r.value)*BPI_DIMS[+r.dataset.i][1];});sc=Math.round(sc);
   let v,c,tipv;if(sc>=80){v="🔥 强爆款潜力";c="var(--teal)";tipv="可优先投放,准备好私域承接与转化路径。";}
   else if(sc>=65){v="✅ 良好,值得一试";c="var(--gold2)";tipv="挑分数最低的 1–2 项优化(通常是钩子或互动设计)再发。";}
   else if(sc>=50){v="⚠️ 中等,需打磨";c="var(--gold)";tipv="重做前 3 秒钩子与情绪点,提升反差感后再测。";}
   else {v="✋ 偏弱,建议重构";c="var(--rose)";tipv="选题或角度本身偏弱,回到痛点库换更尖锐的切入。";}
   $("#bpi-out").innerHTML='<div class="res"><div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap"><span class="scorebig" style="color:'+c+'">'+sc+'</span><div><div class="verdict" style="color:'+c+'">'+v+'</div><p class="micro">满分 100。▸ '+tipv+'</p></div></div></div>';
 };
 // ④ 数据看板
 const tb=$("#dt tbody");
 if(tb){
   if(!tb.dataset.init){tb.dataset.init="1";[["抖音·街访",5000,420,38,120],["小红书·测评",3000,260,29,90],["视频号·科普",2000,150,12,60]].forEach(r=>addDtRow(r));}
   $("#dt-add").onclick=()=>{addDtRow(["新渠道",1000,80,8,50]);dtCalc();};
   $("#dt-csv").onclick=dtCsv;$("#dt-aov").oninput=dtCalc;dtCalc();
 }
 // ⑤ 盈利模型
 const ueGo=$("#ue-go");
 if(ueGo) ueGo.onclick=()=>{
   const p=+$("#ue-p").value||0,c=+$("#ue-c").value||0,cac=+$("#ue-cac").value||0,rep=+$("#ue-rep").value||1;
   const gm1=p-c,gmr=p>0?gm1/p*100:0,ltv=gm1*rep,net=ltv-cac,ratio=cac>0?ltv/cac:99,pay=gm1>0?cac/gm1:99;
   let v,col;if(ratio>=3&&net>0){v="💚 模式健康(LTV/CAC ≥ 3)";col="var(--teal)";}else if(ratio>=1.5){v="🟡 可行,需提升复购或降获客成本";col="var(--gold2)";}else{v="🔴 不健康,单客难回本";col="var(--rose)";}
   $("#ue-out").innerHTML='<div class="res"><div class="verdict" style="color:'+col+'">'+v+'</div><div class="depthead" style="margin:12px 0 0">'+
     chip("单件毛利","¥"+gm1.toFixed(1)+" ("+gmr.toFixed(0)+"%)")+chip("年客户价值 LTV","¥"+ltv.toFixed(1))+chip("单客净利","¥"+net.toFixed(1))+chip("回本所需订单",(pay<99?pay.toFixed(1)+" 单":"—"))+chip("LTV/CAC",(ratio<99?ratio.toFixed(1)+"×":"—"))+'</div></div>';
 };
}
function chip(l,v){return '<div class="chip">'+v+'<small>'+l+'</small></div>';}
function addDtRow(d){const tb=$("#dt tbody");const tr=document.createElement("tr");
 tr.innerHTML='<td><input value="'+d[0]+'"></td><td><input type="number" value="'+d[1]+'"></td><td><input type="number" value="'+d[2]+'"></td><td><input type="number" value="'+d[3]+'"></td><td><input type="number" value="'+d[4]+'"></td><td class="calc cpe">–</td><td class="calc cvr">–</td><td class="calc roi">–</td><td><button class="del">✕</button></td>';
 tr.querySelector(".del").onclick=()=>{tr.remove();dtCalc();};
 $$("input",tr).forEach(i=>i.oninput=dtCalc);tb.appendChild(tr);}
function dtCalc(){const aov=+$("#dt-aov").value||0;let best=-1,bi=null;
 $$("#dt tbody tr").forEach(tr=>{const v=$$("input",tr).map(x=>x.value);const reach=+v[1],eng=+v[2],conv=+v[3],cost=+v[4];
   const cpe=eng>0?cost/eng:0,cvr=reach>0?conv/reach*100:0,roi=cost>0?conv*aov/cost:0;
   tr.querySelector(".cpe").textContent=cpe?("¥"+cpe.toFixed(2)):"–";
   tr.querySelector(".cvr").textContent=cvr?(cvr.toFixed(2)+"%"):"–";
   tr.querySelector(".roi").textContent=roi?(roi.toFixed(2)):"–";
   tr.classList.remove("best");if(cost>0&&roi>best){best=roi;bi=tr;}});
 if(bi)bi.classList.add("best");}
function dtCsv(){let rows=[["渠道/选题","触达","互动","转化","成本","CPE","转化率%","ROI"]];
 $$("#dt tbody tr").forEach(tr=>{const v=$$("input",tr).map(x=>x.value);rows.push([v[0],v[1],v[2],v[3],v[4],tr.querySelector(".cpe").textContent,tr.querySelector(".cvr").textContent,tr.querySelector(".roi").textContent]);});
 const csv="\ufeff"+rows.map(r=>r.map(x=>'"'+String(x).replace(/"/g,'""')+'"').join(",")).join("\n");
 const a=document.createElement("a");a.href=URL.createObjectURL(new Blob([csv],{type:"text/csv"}));a.download="市场测试数据.csv";a.click();}

/* ===== 路由 ===== */
function route(){
 const h=location.hash.replace(/^#/,"")||"/home";const seg=h.split("/").filter(Boolean);
 let html,key;
 if(seg[0]==="track"){const g=+(seg[1]||"t1").replace("t","");html=vTrack(g);key="track";}
 else if(seg[0]==="people"){html=vPeople();key="people";}
 else if(seg[0]==="person"){html=vPerson(+seg[1]);key="people";}
 else if(seg[0]==="system"){html=vSystem();key="system";}
 else if(seg[0]==="deploy"){html=vDeploy();key="deploy";}
 else {html=vHome();key="home";}
 const app=$("#app");app.innerHTML=html;
 $$(".nav a").forEach(a=>{const href=a.getAttribute("href").replace(/^#/,"");a.classList.toggle("on",href===("#"+h).replace(/^#/,"")||a.dataset.k===key&&!(key==="track"));
   if(key==="track")a.classList.toggle("on",href===h);});
 // ensure exact track link highlighted
 if(key==="track"){$$(".nav a").forEach(a=>a.classList.toggle("on",a.getAttribute("href")==="#"+h));}
 closeNav();window.scrollTo(0,0);
 bindTools();
 requestAnimationFrame(()=>$$(".enode").forEach((n,i)=>setTimeout(()=>n.classList.add("in"),i*90)));
}
function toggleNav(){document.body.classList.toggle("navopen");}
function closeNav(){document.body.classList.remove("navopen");}
window.addEventListener("hashchange",route);
window.addEventListener("DOMContentLoaded",()=>{
 route();
 const pf=$("#pfilter");
 document.addEventListener("click",e=>{
   const b=e.target.closest("#pfilter button");if(!b)return;
   $$("#pfilter button").forEach(x=>x.classList.remove("on"));b.classList.add("on");
   const f=b.dataset.f;$$(".pcard").forEach(c=>{c.style.display=(f==="all"||c.dataset.g===f)?"":"none";});
 });
});
if(document.readyState!=="loading"){route();}
</script>
